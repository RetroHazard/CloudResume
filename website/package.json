{
  "name": "cloud-resume-challenge",
  "version": "0.2.5",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@iconify-icon/react": "^2.1.0",
    "@tailwindcss/forms": "^0.5.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-google-recaptcha": "^3.1.0",
    "react-router": "^6.23.0",
    "react-router-dom": "^6.23.0",
    "react-tooltip": "^5.26.4",
    "tailwind-merge": "^2.3.0",
    "tailwind-scrollbar": "^3.1.0",
    "tailwindcss": "^3.4.3",
    "uuid": "^9.0.1"
  },
  "scripts": {
    "test": "vitest run --coverage",
    "start-dev": "cross-env VITE_DATA_SET=development vite",
    "start-prod": "cross-env VITE_DATA_SET=production vite",
    "build-dev": "cross-env VITE_DATA_SET=development vite build --outDir build/dev",
